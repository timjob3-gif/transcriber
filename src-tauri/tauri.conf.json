{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Транскрибатор",
  "version": "1.0.4",
  "identifier": "Transcriber",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "Транскрибатор",
        "width": 720,
        "height": 640,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "resources": {
      "../python/dist/transcriber-core.exe": "."
    },
    "publisher": "timjob3-gif",
    "windows": {
      "nsis": {
        "languages": ["Russian"],
        "displayLanguageSelector": false
      }
    }
  }
}
